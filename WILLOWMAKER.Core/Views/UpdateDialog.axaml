<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="WILLOWMAKER.Core.Views.UpdateDialog"
        Title="Update Available"
        Width="450" Height="180"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <StackPanel Margin="24" VerticalAlignment="Center">
        <TextBlock x:Name="MessageText" TextWrapping="Wrap" Margin="0, 0, 0, 24" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
            <Button Content="Update" Click="Update_Click" />
            <Button Content="Not Now" Click="Skip_Click" />
        </StackPanel>
    </StackPanel>

</Window>
