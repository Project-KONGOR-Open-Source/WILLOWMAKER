<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WILLOWMAKER.Core.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1250" Width="1250" d:DesignHeight="750" Height="750"
             x:Class="WILLOWMAKER.Core.Views.MainView"
             x:DataType="vm:MainViewModel">

    <Design.DataContext>
        <vm:MainViewModel /> <!-- This Only Sets The DataContext For The Previewer In An IDE, To Set The Actual DataContext For Runtime, Set The DataContext Property In Code -->
    </Design.DataContext>

    <!-- Colours & Palettes: https://materialui.co/ -->

    <StackPanel>
        <Grid ColumnDefinitions="Auto, Auto" Height="750">
            <StackPanel Grid.Column="0" Width="150" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#131418">
                <Button Height="150" Command="{Binding GoToURLCommand}" CommandParameter="{Binding GitHubLink}" Cursor="Hand" Background="#131418" >
                    <Image Source="/Assets/github-logo.png" Margin="15" />
                    <Button.Styles>
                        <Style Selector="Button:pointerover > Image">
                            <Setter Property="Width" Value="130" />
                            <Setter Property="Height" Value="130" />
                            <Setter Property="Margin" Value="10"/>
                        </Style>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#131418" />
                        </Style>
                    </Button.Styles>
                </Button>
                <Button Height="150" Command="{Binding GoToURLCommand}" CommandParameter="{Binding WebPortalLink}" Cursor="Hand" Background="#131418" >
                    <Image Source="/Assets/world-wide-web.png" Margin="15" />
                    <Button.Styles>
                        <Style Selector="Button:pointerover > Image">
                            <Setter Property="Width" Value="130" />
                            <Setter Property="Height" Value="130" />
                            <Setter Property="Margin" Value="10"/>
                        </Style>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#131418" />
                        </Style>
                    </Button.Styles>
                </Button>
                <Button Height="150" Command="{Binding GoToURLCommand}" CommandParameter="{Binding RedditLink}" Cursor="Hand" Background="#131418" >
                    <Image Source="/Assets/reddit-logo.png" Margin="15" />
                    <Button.Styles>
                        <Style Selector="Button:pointerover > Image">
                            <Setter Property="Width" Value="130" />
                            <Setter Property="Height" Value="130" />
                            <Setter Property="Margin" Value="10"/>
                        </Style>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#131418" />
                        </Style>
                    </Button.Styles>
                </Button>
                <Button Height="150" Command="{Binding GoToURLCommand}" CommandParameter="{Binding DiscordLink}" Cursor="Hand" Background="#131418" >
                    <Image Source="/Assets/discord-logo.png" Margin="15" />
                    <Button.Styles>
                        <Style Selector="Button:pointerover > Image">
                            <Setter Property="Width" Value="130" />
                            <Setter Property="Height" Value="130" />
                            <Setter Property="Margin" Value="10"/>
                        </Style>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#131418" />
                        </Style>
                    </Button.Styles>
                </Button>
                <Button Height="150" Command="{Binding GoToURLCommand}" CommandParameter="{Binding ElementLink}" Cursor="Hand" Background="#131418" >
                    <Image Source="/Assets/element-logo.png" Margin="15" />
                    <Button.Styles>
                        <Style Selector="Button:pointerover > Image">
                            <Setter Property="Width" Value="130" />
                            <Setter Property="Height" Value="130" />
                            <Setter Property="Margin" Value="10"/>
                        </Style>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#131418" />
                        </Style>
                    </Button.Styles>
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="1" Width="1100" Background="#131418" Focusable="True" PointerPressed="Background_PointerPressed">
                <StackPanel.Background>
                    <ImageBrush Source="/Assets/caldavar.png" Stretch="UniformToFill" Opacity="0.20" />
                </StackPanel.Background>

                <Grid RowDefinitions="Auto, Auto">
                    <Grid Grid.Row="0" Height="700" ColumnDefinitions="Auto, Auto, Auto">
                        <StackPanel Grid.Column="0" Width="350" />

                        <StackPanel Grid.Column="1" Width="400" Margin="0, 280, 0, 0">
                            <Label Width="400" Margin="0, 0, 0, 5" HorizontalAlignment="Center" HorizontalContentAlignment="Center">Master Server Address</Label>

                            <ComboBox SelectedValue="{Binding MasterServerAddress}" Name="MasterServerAddressDropdown" SelectedIndex="0" Width="400" HorizontalAlignment="Center" HorizontalContentAlignment="Center" IsEnabled="{Binding SynchronisationIsIdle}">
                                <ComboBoxItem HorizontalContentAlignment="Stretch">api.kongor.net</ComboBoxItem>
                                <ComboBoxItem HorizontalContentAlignment="Stretch">localhost:5555</ComboBoxItem>
                                <ComboBoxItem HorizontalContentAlignment="Stretch">Custom Address ...</ComboBoxItem>
                            </ComboBox>

                            <TextBox Text="{Binding CustomMasterServerAddress}" Width="400" Margin="0, 10, 0, 0" HorizontalAlignment="Center" TextAlignment="Center" IsVisible="{Binding CanShowCustomMasterServerAddressField}" IsEnabled="{Binding SynchronisationIsIdle}" LostFocus="CustomMasterServerAddress_LostFocus" KeyDown="CustomMasterServerAddress_KeyDown" />

                            <StackPanel Orientation="Horizontal" Margin="0, 10, 0, 0" HorizontalAlignment="Center">
                                <Button Command="{Binding LaunchMapEditorCommand}" Width="175" Height="60" Margin="0, 0, 5, 0" Cursor="Hand" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" IsEnabled="{Binding CanLaunchMapEditor}" Background="DarkGreen">
                                    <Button.Styles>
                                        <Style Selector="Button TextBlock">
                                            <Setter Property="RenderTransform" Value="scale(1)" />
                                            <Setter Property="FontWeight" Value="Normal" />
                                        </Style>
                                        <Style Selector="Button:pointerover TextBlock">
                                            <Setter Property="RenderTransform" Value="scale(1.10)" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </Style>
                                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                                            <Setter Property="Background" Value="Green" />
                                        </Style>
                                    </Button.Styles>

                                    <TextBlock Text="Open Map Editor" RenderTransformOrigin="50%, 50%">
                                        <TextBlock.Transitions>
                                            <Transitions>
                                                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25" Easing="CubicEaseOut" />
                                            </Transitions>
                                        </TextBlock.Transitions>
                                    </TextBlock>
                                </Button>

                                <Button Command="{Binding LaunchGameClientCommand}" Width="215" Height="60" Margin="5, 0, 0, 0" Cursor="Hand" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" IsEnabled="{Binding CanLaunchGameClient}" Background="DarkGreen">
                                    <Button.Styles>
                                        <Style Selector="Button TextBlock">
                                            <Setter Property="RenderTransform" Value="scale(1)" />
                                            <Setter Property="FontWeight" Value="Normal" />
                                        </Style>
                                        <Style Selector="Button:pointerover TextBlock">
                                            <Setter Property="RenderTransform" Value="scale(1.10)" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </Style>
                                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                                            <Setter Property="Background" Value="Green" />
                                        </Style>
                                    </Button.Styles>

                                    <TextBlock Text="{Binding PlayButtonText}" RenderTransformOrigin="50%, 50%">
                                        <TextBlock.Transitions>
                                            <Transitions>
                                                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25" Easing="CubicEaseOut" />
                                            </Transitions>
                                        </TextBlock.Transitions>
                                    </TextBlock>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <Grid Grid.Column="2" Width="350" VerticalAlignment="Top" Margin="0, 15, 0, 0" ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Foreground="OrangeRed" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="5, 0"
                                   Content="Releases Repository Not Reachable"
                                   IsVisible="{Binding ReleasesRepositoryIsUnreachable}" />
                            <Label Grid.Column="1" Content="{Binding VersionDisplay}" Padding="5, 0, 0, 0" Margin="0, 0, 15, 0" />
                        </Grid>
                    </Grid>

                    <StackPanel Grid.Row="1" Height="40">
                        <!-- Synchronisation Success State: Four Columns With Synchronisation File Data -->
                        <Grid Height="20" Margin="10, 0, 10, 0" ColumnDefinitions="*, *, *, *" IsVisible="{Binding !SynchronisationIsFailed}">
                            <TextBlock Grid.Column="0" Text="{Binding DownloadedFilesDisplay}" HorizontalAlignment="Left"   VerticalAlignment="Center" FontSize="10" Foreground="#CCCCCC" />
                            <TextBlock Grid.Column="1" Text="{Binding RemovedFilesDisplay}"    HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" Foreground="#CCCCCC" />
                            <TextBlock Grid.Column="2" Text="{Binding SkippedFilesDisplay}"    HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" Foreground="#CCCCCC" />
                            <TextBlock Grid.Column="3" Text="{Binding UpToDateFilesDisplay}"   HorizontalAlignment="Right"  VerticalAlignment="Center" FontSize="10" Foreground="#CCCCCC" />
                        </Grid>

                        <!-- Synchronisation Failure State: A Single Centred Failure Message -->
                        <TextBlock Height="20" Margin="10, 0, 10, 0" Text="{Binding SynchronisationStatusMessage}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" Foreground="#CCCCCC" IsVisible="{Binding SynchronisationIsFailed}" />

                        <ProgressBar Width="1080" Height="5" Margin="0, 0, 0, 0" Minimum="0" Maximum="100" Value="{Binding SynchronisationProgressPercent}" IsVisible="{Binding SynchronisationIsScheduled}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </StackPanel>

</UserControl>
