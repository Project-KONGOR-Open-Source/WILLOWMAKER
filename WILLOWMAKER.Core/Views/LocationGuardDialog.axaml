<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="WILLOWMAKER.Core.Views.LocationGuardDialog"
        Title="Dangerous Location"
        Width="450" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        TransparencyLevelHint="Transparent"
        Background="#F2131418">

    <StackPanel Margin="25">
        <TextBlock x:Name="MessageText" TextWrapping="Wrap" Margin="0, 0, 0, 15" />
        <Expander x:Name="DetailsExpander" Header="More Information" IsExpanded="False" Margin="0, 0, 0, 15" HorizontalAlignment="Stretch">
            <StackPanel Spacing="8">
                <TextBlock x:Name="ReasonHeading" Text="Reason" FontWeight="SemiBold" />
                <TextBlock x:Name="ReasonText" TextWrapping="Wrap" />
                <TextBlock x:Name="ForeignEntriesHeading" Text="Foreign Entries" FontWeight="SemiBold" Margin="0, 6, 0, 0" />
                <ScrollViewer x:Name="ForeignEntriesScroll" MaxHeight="180" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="ForeignEntriesText" TextWrapping="Wrap" FontFamily="Cascadia Mono, Consolas, Menlo, Monospace" />
                </ScrollViewer>
            </StackPanel>
        </Expander>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button Content="OK" Click="OK_Click" Background="Green" Cursor="Hand" Width="90" Height="30" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="Green" />
                        <Setter Property="FontWeight" Value="Medium" />
                    </Style>
                </Button.Styles>
            </Button>
        </StackPanel>
    </StackPanel>

</Window>
