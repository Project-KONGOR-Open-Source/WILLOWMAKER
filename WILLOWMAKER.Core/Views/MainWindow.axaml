<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WILLOWMAKER.Core.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:WILLOWMAKER.Core.Views"
        mc:Ignorable="d" d:DesignWidth="1250" Width="1250" d:DesignHeight="750" Height="750"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        x:Class="WILLOWMAKER.Core.Views.MainWindow"
        Icon="/Assets/willowmaker.png"
        Title="WILLOWMAKER">

        <views:MainView />
</Window>
